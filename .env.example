# Sepolia deployment için gerekli (npx hardhat run deploy.js --network sepolia)
SEPOLIA_RPC_URL=
PRIVATE_KEY=

# Vercel production ortamı için gerekli (Dashboard → Settings → Environment Variables)
# PINATA_JWT=             ← /api/upload-ipfs serverless fonksiyonu bu değişkeni kullanır
# KEY_DERIVATION_SECRET=  ← calldata şifrelemesi için (openssl rand -hex 32)
# SEPOLIA_RPC_URL=        ← /api/get-key on-chain doğrulama için (boşsa Ankr public kullanılır)
